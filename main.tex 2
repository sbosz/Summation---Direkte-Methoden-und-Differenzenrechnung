\section{1. Einleitung und Motivation}

\begin{frame}{Einleitung und Motivation}
    \begin{itemize}
        \item \textbf{Zentrales Problem der diskreten Mathematik:} Bestimmung geschlossener Darstellungen für endliche Summen der Form:
        \[ S_{n}=\sum_{k=a}^{b}g(k) \]
        \item \textbf{Geschlossene Form:} Eine Darstellung, die ohne explizite Summenzeichen auskommt und sich durch eine endliche Kombination elementarer Operationen ausdrücken lässt.
        \item \textbf{Motivation:} Das schrittweise Aufaddieren per Hand benötigt eine Anzahl an Rechenschritten, die linear wächst. Eine geschlossene Formel erlaubt eine direkte Berechnung.
        \item \textbf{Ziel des Vortrags:} Methoden zur Berechnung endlicher Summen vorstellen.
    \end{itemize}
\end{frame}

\section{2. Direkte Methoden}

\begin{frame}{Das Prinzip der Indextransformation}
    
        Bei der Indexverschiebung wird eine Verschiebung der Laufgrenzen durch eine entgegengesetzte Operation im Inneren ausgeglichen:
        \[ \sum_{k=a}^{b}g(k)=\sum_{k=a+m}^{b+m}g(k-m) \]
    
    \textbf{Beispiel:} Normierung der Summe $S=\sum_{k=3}^{6}k$ auf Startwert 1 ($m=-2$):
    \begin{itemize}
        \item Grenzen: $3 \to 3-2=1$ und $6 \to 6-2=4$.
        \item Summand: $k \to k-(-2) = k+2$.
        \[ \sum_{k=3}^{6}k = \sum_{k=1}^{4}(k+2) = (1+2) + (2+2) + (3+2) + (4+2) = 18 \]
    \end{itemize}
\end{frame}

\begin{frame}{Isolation von Randtermen}
    \begin{itemize}
        \item \textbf{Idee:} Einzelne Summanden gezielt isolieren (meist ersten oder letzten Term), sodass sich eine Beziehung zwischen zwei Summen ergbit.
    \end{itemize}
    \textbf{Beispiel: Herleitung der geometrischen Reihe} \\
    Wir betrachten $S_{n} = \sum_{k=0}^{n}q^{k}$ und stellen $S_{n+1}$ auf zwei Weisen dar:
    \begin{enumerate}
        \item \textbf{Letzten Term abspalten:}
        \[ S_{n+1} = S_n + q^{n+1} \]
        \item \textbf{Ersten Term abspalten \& Indexverschiebung:}
        \[ S_{n+1} = q^0 + \sum_{k=1}^{n+1}q^{k} = 1 + q \sum_{k=0}^{n}q^{k} = 1 + qS_n \]
    \end{enumerate}
\end{frame}

\begin{frame}{Isolation von Randtermen}
    Gleichsetzen der beiden Ausdrücke für $S_{n+1}$:
    \[ S_n + q^{n+1} = 1 + qS_n \]
    Algebraische Umformung:
    \begin{align*}
        S_n - qS_n &= 1 - q^{n+1} \\
        S_n(1 - q) &= 1 - q^{n+1}
    \end{align*}
    Für $q \neq 1$ folgt die bekannte geschlossene Form:
    \[ S_n = \frac{1-q^{n+1}}{1-q} \]
\end{frame}

\begin{frame}{Vollständige Induktion}
    Hat man durch Experimentieren oder Heuristiken eine Vermutung für eine geschlossene Formel aufgestellt, ist die Induktion das Standardverfahren für den Beweis.
    \end{frame}

\begin{frame}{Vollständige Induktion}
        Für alle $n\in\mathbb{N}$ gilt:
        \[ \sum_{k=1}^{n}(2k-1)=n^{2} \]
    \textbf{Beweis:}\\
     \textbf{(Induktionsanfang $n = 1$):}
     \begin{align*}
        \sum_{k=1}^{1}(2k-1) &= 2(1)-1 = 1 = 1^2
    \end{align*}
     \textbf{(Induktionsschritt $n \to n+1$):}
    \begin{align*}
        \sum_{k=1}^{n+1}(2k-1) &= \left(\sum_{k=1}^{n}(2k-1)\right) + (2(n+1)-1) \\
        &\overset{IV}{=} n^2 + (2n + 2 - 1) \\
        &= n^2 + 2n + 1 = (n+1)^2 \quad \square
    \end{align*}
\end{frame}

